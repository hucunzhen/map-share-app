<!-- pages/home/home.wxml -->
<view class="container">

  <!-- 视图切换 -->
  <view class="view-switch">
    <view 
      class="switch-btn {{viewMode === 'list' ? 'active' : ''}}" 
      bindtap="switchView" 
      data-mode="list">
      列表
    </view>
    <view 
      class="switch-btn {{viewMode === 'map' ? 'active' : ''}}" 
      bindtap="switchView" 
      data-mode="map">
      地图
    </view>
  </view>

  <!-- 列表视图 -->
  <view wx:if="{{viewMode === 'list'}}">
    <view wx:if="{{listData.length > 0}}">
      <location-card
        wx:for="{{listData}}"
        wx:key="_id"
        title="{{item.title}}"
        address="{{item.description}}"
        bind:tap="goDetail"
        data-id="{{item._id}}" />

      <!-- 加载更多 -->
      <view class="loading" wx:if="{{loading}}">
        <text>加载中...</text>
      </view>
      <view class="no-more" wx:if="{{!hasMore && listData.length > 0}}">
        <text>— 没有更多了 —</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="empty-state">
      <text>还没有位置信息</text>
      <text>快去发布第一条吧</text>
    </view>
  </view>

  <!-- 地图视图 -->
  <view wx:if="{{viewMode === 'map'}}" class="map-container">
    <map
      id="map"
      class="map"
      latitude="{{latitude}}"
      longitude="{{longitude}}"
      scale="{{scale}}"
      markers="{{markers}}"
      show-location
      bindmarkertap="onMarkerTap">
    </map>
    
    <!-- 地图底部提示 -->
    <view class="map-tip">
      <text>点击标记查看详情并导航</text>
    </view>
  </view>

</view>