/* pages/chat/chat.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f0f0f0;
}

/* 关联位置提示 */
.location-hint {
  padding: 16rpx 30rpx;
  background: #fff8e6;
  font-size: 24rpx;
  color: #e6a700;
  text-align: center;
  border-bottom: 1rpx solid #ffeaa7;
}

/* 消息列表 */
.msg-list {
  flex: 1;
  padding: 20rpx 24rpx;
  padding-bottom: 120rpx;
  overflow-y: auto;
}

.load-more {
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #999;
}

.loading-state {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

/* 消息项 */
.msg-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.msg-item.mine {
  flex-direction: row-reverse;
}

/* 头像 */
.msg-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
}

.avatar-default {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.avatar-default.me {
  background: #07c160;
}

/* 气泡 */
.msg-bubble-wrap {
  max-width: 65%;
  margin: 0 16rpx;
}

.msg-sender {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
  display: block;
}

.msg-bubble {
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  word-break: break-all;
}

.other .msg-bubble {
  background: #fff;
  border-top-left-radius: 4rpx;
}

.mine .msg-bubble {
  background: #07c160;
  border-top-right-radius: 4rpx;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.6;
}

.other .msg-text {
  color: #333;
}

.mine .msg-text {
  color: #fff;
}

.msg-time {
  font-size: 20rpx;
  color: #bbb;
  margin-top: 6rpx;
  display: block;
}

.mine .msg-time {
  text-align: right;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state .hint {
  display: block;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 12rpx;
}

/* 输入栏 */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
  z-index: 100;
}

.msg-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  padding: 0 32rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 36rpx;
  background: #e0e0e0;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  transition: background 0.2s;
}

.send-btn.active {
  background: #07c160;
}