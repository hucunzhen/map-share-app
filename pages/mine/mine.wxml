<!-- pages/mine/mine.wxml -->
<view class="container">

  <!-- 用户信息卡片 -->
  <view class="user-card">
    <!-- 未登录 -->
    <block wx:if="{{!isLoggedIn}}">
      <view class="default-avatar">👤</view>
      <view class="user-info">
        <text class="name">未登录</text>
        <text class="sub">登录后可发布和收藏</text>
      </view>
    </block>
    <!-- 已登录 -->
    <block wx:else>
      <image class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill" />
      <view class="user-info">
        <text class="name">{{userInfo.nickName}}</text>
        <text class="sub">{{myPosts.length}} 条发布 · {{myFavorites.length}} 条收藏</text>
      </view>
      <view class="logout-btn" bindtap="onLogout">退出</view>
    </block>
  </view>

  <!-- 登录表单 -->
  <view class="login-form card" wx:if="{{!isLoggedIn}}">
    <view class="form-title">登录账号</view>

    <!-- 头像选择 -->
    <view class="form-item">
      <text class="form-label">头像</text>
      <button class="avatar-chooser" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{tempAvatarUrl}}" class="chosen-avatar" src="{{tempAvatarUrl}}" mode="aspectFill" />
        <view wx:else class="avatar-placeholder">
          <text class="plus-icon">+</text>
          <text class="hint-text">选择头像</text>
        </view>
      </button>
    </view>

    <!-- 昵称输入 -->
    <view class="form-item">
      <text class="form-label">昵称</text>
      <input
        class="nickname-input"
        type="nickname"
        placeholder="请输入昵称"
        bindchange="onNicknameInput"
        value="{{tempNickName}}" />
    </view>

    <!-- 登录按钮 -->
    <button class="btn-primary login-btn" bindtap="onLogin">
      登录
    </button>
  </view>

  <!-- 登录后的内容区域 -->
  <view wx:if="{{isLoggedIn}}">

    <!-- 功能入口 -->
    <view class="func-entries">
      <view class="func-item" bindtap="goMessages">
        <text class="func-icon">💬</text>
        <text class="func-name">我的消息</text>
      </view>
    </view>

    <!-- 标签切换 -->
    <view class="tab-bar">
      <view
        class="tab {{activeTab === 'posts' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="posts">
        我的发布
      </view>
      <view
        class="tab {{activeTab === 'favorites' ? 'active' : ''}}"
        bindtap="switchTab"
        data-tab="favorites">
        我的收藏
      </view>
    </view>

    <!-- 我的发布列表 -->
    <view wx:if="{{activeTab === 'posts'}}">
      <view wx:if="{{myPosts.length > 0}}">
        <view
          wx:for="{{myPosts}}"
          wx:key="_id"
          class="item-card">

          <view bindtap="goDetail" data-id="{{item._id}}">
            <view class="item-title">{{item.title}}</view>
            <view class="item-desc" wx:if="{{item.description}}">{{item.description}}</view>
            <view class="item-meta">
              <text class="coords">{{item.latitude.toFixed(4)}}, {{item.longitude.toFixed(4)}}</text>
              <text class="time">{{item.createTime}}</text>
            </view>
          </view>

          <view class="item-actions">
            <view class="action-btn" bindtap="goNavigate" data-lat="{{item.latitude}}" data-lon="{{item.longitude}}" data-name="{{item.title}}">
              🧭 导航
            </view>
            <view class="action-btn delete" bindtap="deletePost" data-id="{{item._id}}">
              🗑️ 删除
            </view>
          </view>

        </view>
      </view>
      <view wx:else class="empty-state">
        <text>还没有发布</text>
        <text>去发布第一条位置信息吧</text>
      </view>
    </view>

    <!-- 我的收藏列表 -->
    <view wx:if="{{activeTab === 'favorites'}}">
      <view wx:if="{{myFavorites.length > 0}}">
        <view
          wx:for="{{myFavorites}}"
          wx:key="_id"
          class="item-card">

          <view bindtap="goDetail" data-id="{{item._id}}">
            <view class="item-title">{{item.title}}</view>
            <view class="item-desc" wx:if="{{item.description}}">{{item.description}}</view>
            <view class="item-meta">
              <text class="coords">{{item.latitude.toFixed(4)}}, {{item.longitude.toFixed(4)}}</text>
              <text class="time">{{item.createTime}}</text>
            </view>
          </view>

          <view class="item-actions">
            <view class="action-btn" bindtap="goNavigate" data-lat="{{item.latitude}}" data-lon="{{item.longitude}}" data-name="{{item.title}}">
              🧭 导航
            </view>
            <view class="action-btn delete" bindtap="removeFavorite" data-id="{{item._id}}">
              ⭐ 取消收藏
            </view>
          </view>

        </view>
      </view>
      <view wx:else class="empty-state">
        <text>还没有收藏</text>
        <text>收藏感兴趣的位置信息</text>
      </view>
    </view>

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading">
      <text>加载中...</text>
    </view>

  </view>

</view>