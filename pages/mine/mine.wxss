/* pages/mine/mine.wxss */

/* 用户信息卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.default-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.8);
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.user-info .name {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.user-info .sub {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.logout-btn {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  padding: 8rpx 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 24rpx;
  flex-shrink: 0;
}

/* 登录表单 */
.login-form {
  margin-bottom: 24rpx;
}

.form-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 32rpx;
}

.form-item {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  width: 100rpx;
  flex-shrink: 0;
}

.avatar-chooser {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #f0f0f0;
  padding: 0;
  margin: 0;
  border: none;
  line-height: normal;
  overflow: hidden;
}

.avatar-chooser::after {
  border: none;
}

.chosen-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
}

.avatar-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.plus-icon {
  font-size: 40rpx;
  color: #999999;
  line-height: 1;
}

.hint-text {
  font-size: 20rpx;
  color: #999999;
  margin-top: 4rpx;
}

.nickname-input {
  flex: 1;
  height: 72rpx;
  background: #f5f6f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.login-btn {
  width: 100%;
  margin-top: 16rpx;
}

/* 标签切换 */
.tab-bar {
  display: flex;
  background: #ffffff;
  border-radius: 12rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 28rpx;
  color: #666666;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.tab.active {
  background: #3b82f6;
  color: #ffffff;
  font-weight: 600;
}

/* 列表项 */
.item-card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.item-desc {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.item-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 24rpx;
  color: #999999;
}

.coords {
  color: #3b82f6;
}

.item-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 12rpx 0;
  font-size: 26rpx;
  color: #3b82f6;
  background: #f0f7ff;
  border-radius: 8rpx;
}

.action-btn.delete {
  color: #ef4444;
  background: #fef2f2;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx 0;
  color: #999999;
  font-size: 26rpx;
}

/* 功能入口 */
.func-entries {
  display: flex;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
}

.func-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.func-item:active {
  opacity: 0.7;
}

.func-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.func-name {
  font-size: 24rpx;
  color: #666;
}