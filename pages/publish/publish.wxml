<!-- pages/publish/publish.wxml -->
<view class="container">

  <!-- 位置信息 -->
  <view class="section">
    <view class="section-title">
      <text class="icon">📍</text>
      <text>位置信息</text>
    </view>

    <view class="location-box" bindtap="chooseLocation">
      <view wx:if="{{locationLoading}}" class="location-loading">
        <text>正在获取位置...</text>
      </view>
      <view wx:elif="{{hasLocation}}" class="location-info">
        <text class="address">{{address || '已获取坐标'}}</text>
        <text class="coords">{{latitude.toFixed(6)}}, {{longitude.toFixed(6)}}</text>
      </view>
      <view wx:else class="location-empty" bindtap="getLocation">
        <text>点击获取当前位置</text>
        <text class="hint">或点击此处手动选择位置</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="section">
    <view class="section-title">
      <text class="icon">📝</text>
      <text>基本信息</text>
    </view>

    <view class="input-group">
      <view class="input-item">
        <text class="label">标题</text>
        <input 
          class="input" 
          placeholder="给这个地点起个名字" 
          value="{{title}}"
          bindinput="onTitleInput"
          maxlength="50" />
      </view>

      <view class="input-item">
        <text class="label">描述</text>
        <textarea 
          class="textarea" 
          placeholder="描述一下这个地点（选填）" 
          value="{{description}}"
          bindinput="onDescInput"
          maxlength="500"
          auto-height />
      </view>
    </view>
  </view>

  <!-- 图片上传 -->
  <view class="section">
    <view class="section-title">
      <text class="icon">🖼️</text>
      <text>添加图片</text>
      <text class="sub">（选填，最多9张）</text>
    </view>

    <view class="images-grid">
      <view 
        wx:for="{{images}}" 
        wx:key="index"
        class="image-item">
        <image src="{{item.tempFilePath}}" mode="aspectFill" />
        <view class="image-delete" bindtap="deleteImage" data-index="{{index}}">×</view>
      </view>

      <view 
        wx:if="{{images.length < maxImages}}" 
        class="add-image" 
        bindtap="chooseImages">
        <text class="plus">+</text>
        <text class="text">添加图片</text>
      </view>
    </view>
  </view>

  <!-- 发布按钮 -->
  <view class="btn-area">
    <button 
      class="btn-publish {{loading ? 'loading' : ''}}" 
      bindtap="submit"
      disabled="{{loading}}">
      {{loading ? '发布中...' : '发布位置信息'}}
    </button>
  </view>

</view>