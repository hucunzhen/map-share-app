/* pages/chatlist/chatlist.wxss */

.container {
  padding: 0;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 公共聊天室入口 */
.public-chat-entry {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.public-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #07c160, #06ad56);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  flex-shrink: 0;
}

.public-info {
  flex: 1;
  margin-left: 24rpx;
}

.public-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: block;
}

.public-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
  display: block;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 12rpx;
}

/* 会话列表标题 */
.section-title {
  padding: 20rpx 30rpx 10rpx;
  font-size: 26rpx;
  color: #999;
}

/* 会话条目 */
.chat-item {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.chat-item:active {
  background: #f9f9f9;
}

.chat-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-img {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
}

.avatar-default {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.chat-info {
  flex: 1;
  margin-left: 24rpx;
  overflow: hidden;
}

.chat-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chat-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.chat-time {
  font-size: 24rpx;
  color: #bbb;
}

.chat-last-msg {
  font-size: 26rpx;
  color: #999;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* 加载和空状态 */
.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999;
  font-size: 28rpx;
}

.empty-state .hint {
  display: block;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 12rpx;
}