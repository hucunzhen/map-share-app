/* app.wxss */
page {
  background-color: #f5f6f8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6, #60a5fa);
  color: #ffffff;
  border: none;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #ffffff;
  color: #3b82f6;
  border: 2rpx solid #3b82f6;
  border-radius: 12rpx;
  font-size: 32rpx;
  padding: 24rpx 48rpx;
}

.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: #e0f2fe;
  color: #0284c7;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.empty-state {
  text-align: center;
  padding: 120rpx 0;
  color: #999999;
  font-size: 28rpx;
}