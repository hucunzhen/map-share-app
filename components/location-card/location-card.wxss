/* components/location-card/location-card.wxss */
.location-card {
  background: #ffffff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.address {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.distance {
  font-size: 24rpx;
  color: #3b82f6;
}